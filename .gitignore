# Model weights (large binary files — do not commit)
weights/*.pt
weights/*.pth
weights/*.joblib
weights/*.pkl

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Secrets — NEVER commit
.env
.streamlit/secrets.toml

# Environments
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Streamlit
.streamlit/
